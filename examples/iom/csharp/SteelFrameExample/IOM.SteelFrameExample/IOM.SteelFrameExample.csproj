<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <ProjectGuid>{8B5CEAF9-0553-4156-ABFA-B8A27E251514}</ProjectGuid>
    <TargetFramework>netstandard2.0</TargetFramework>
    <AppendTargetFrameworkToOutputPath>false</AppendTargetFrameworkToOutputPath>
    <AssemblyTitle>IOM.SteelFrameExample</AssemblyTitle>
    <Product>IOM.SteelFrameExample</Product>
    <Copyright>Copyright ©  2020</Copyright>
    <OutputPath>bin\$(Configuration)\</OutputPath>
    <Configurations>Debug;Release;Debug_NuGet;Release_NuGet</Configurations>
  </PropertyGroup>
  <PropertyGroup Condition=" '$(Configuration)|$(Platform)' == 'Debug|AnyCPU' ">
    <DebugType>full</DebugType>
    <TreatWarningsAsErrors>True</TreatWarningsAsErrors>
  </PropertyGroup>
  <PropertyGroup Condition="'$(Configuration)|$(Platform)'=='Debug_NuGet|AnyCPU'">
    <DebugType>full</DebugType>
    <TreatWarningsAsErrors>True</TreatWarningsAsErrors>
  </PropertyGroup>
  <PropertyGroup Condition=" '$(Configuration)|$(Platform)' == 'Release|AnyCPU' ">
    <DebugType>pdbonly</DebugType>
    <TreatWarningsAsErrors>True</TreatWarningsAsErrors>
  </PropertyGroup>
	<PropertyGroup Condition=" '$(Configuration)|$(Platform)' == 'Release_NuGet|AnyCPU' ">
		<DebugType>pdbonly</DebugType>
		<TreatWarningsAsErrors>True</TreatWarningsAsErrors>
	</PropertyGroup>	
	
  <ItemGroup>
    <PackageReference Include="Newtonsoft.Json" />
  </ItemGroup>
  <ItemGroup>
    <None Include="SampleFiles\con-n2.ideaCon">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </None>
    <None Include="SampleFiles\connectionFromIOM-web.ideaCon">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </None>
    <None Include="SampleFiles\IOM-SteelFrame.xmlR">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </None>
  </ItemGroup>
  <ItemGroup>
    <None Include="SampleFiles\IOM-SteelFrame.xml">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </None>
  </ItemGroup>

  <ItemGroup Condition="$(Configuration.Contains('NuGet'))">
	<PackageReference Include="IdeaStatiCa.OpenModel"/>
  </ItemGroup>	
  <ItemGroup Condition="'$(Configuration)' == 'Debug' Or '$(Configuration)' == 'Release'">
    <ProjectReference Include="..\..\..\..\..\src\IdeaRS.OpenModel\IdeaRS.OpenModel.csproj" />
  </ItemGroup>

  <!-- Dual-API example: the source build (IdeaStatiCa.Public.sln, Debug/Release) uses the new
       3.3.x connection API, while the NuGet build (IdeaStatiCa-SDK-Examples.sln, *_NuGet configs)
       still builds against the published package's pre-3.3 API. Compile the matching copy per
       config. Collapse back to a single SteelFrameExample.cs once the 3.3.x package is published. -->
  <ItemGroup Condition="$(Configuration.Contains('NuGet'))">
    <Compile Remove="SteelFrameExample.cs" />
  </ItemGroup>
  <ItemGroup Condition="!$(Configuration.Contains('NuGet'))">
    <Compile Remove="SteelFrameExample.NuGet.cs" />
  </ItemGroup>
</Project>