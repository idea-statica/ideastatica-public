<Window x:Class="NorsokChecker.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="IDEA StatiCa — NORSOK N-004 Connection Checker"
        Width="1100" Height="780"
        WindowStartupLocation="CenterScreen"
        Style="{StaticResource MaterialDesignWindow}"
        TextElement.Foreground="{DynamicResource MaterialDesign.Brush.Foreground}"
        Background="#F0F2F5">

    <Window.Resources>
        <!-- IDEA StatiCa brand -->
        <Color x:Key="IdeaOrange">#F57C00</Color>
        <Color x:Key="IdeaDark">#2D2D2D</Color>
        <SolidColorBrush x:Key="IdeaOrangeBrush" Color="{StaticResource IdeaOrange}"/>
        <SolidColorBrush x:Key="IdeaDarkBrush" Color="{StaticResource IdeaDark}"/>
        <!-- Norsok accent -->
        <Color x:Key="NorsokTeal">#00838F</Color>
        <Color x:Key="NorsokTealLight">#4FB3BF</Color>
        <SolidColorBrush x:Key="NorsokTealBrush" Color="{StaticResource NorsokTeal}"/>

        <!-- Button styles -->
        <Style x:Key="IdeaPrimaryButton" TargetType="Button" BasedOn="{StaticResource MaterialDesignRaisedButton}">
            <Setter Property="Background" Value="{StaticResource IdeaOrangeBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="md:ElevationAssist.Elevation" Value="Dp2"/>
        </Style>
        <Style x:Key="IdeaOutlineButton" TargetType="Button" BasedOn="{StaticResource MaterialDesignOutlinedButton}">
            <Setter Property="BorderBrush" Value="{StaticResource IdeaOrangeBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource IdeaOrangeBrush}"/>
            <Setter Property="Padding" Value="12,4"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ═══ Header — IDEA StatiCa primary with orange accent ═══ -->
        <Border Grid.Row="0" md:ElevationAssist.Elevation="Dp4">
            <Border.Background>
                <SolidColorBrush Color="{StaticResource IdeaDark}"/>
            </Border.Background>
            <Grid Margin="20,12,20,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Left: IDEA StatiCa brand -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <!-- Orange bar accent (like IDEA logo) -->
                    <Border Width="4" Height="32" Background="{StaticResource IdeaOrangeBrush}"
                            CornerRadius="2" Margin="0,0,12,0"/>
                    <StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="IDEA" FontSize="19" FontWeight="Bold" Foreground="#F57C00"/>
                            <TextBlock Text=" StatiCa" FontSize="19" FontWeight="SemiBold" Foreground="White"/>
                        </StackPanel>
                        <TextBlock Text="Connection API" FontSize="10" Foreground="#9E9E9E"
                                   Margin="0,-2,0,0"/>
                    </StackPanel>
                </StackPanel>

                <!-- Center: divider + Norsok feature badge -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center"
                            HorizontalAlignment="Center">
                    <Border Background="#3E3E3E" Width="1" Height="28" Margin="20,0,20,0"/>
                    <Grid Width="28" Height="28" Margin="0,0,10,0">
                        <Ellipse Fill="#00838F" Opacity="0.2"/>
                        <md:PackIcon Kind="ShieldCheck" Width="16" Height="16"
                                     Foreground="#4FB3BF" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Grid>
                    <StackPanel>
                        <TextBlock Text="NORSOK N-004" FontSize="14" FontWeight="SemiBold" Foreground="#4FB3BF"/>
                        <TextBlock Text="Connection Compliance Checker" FontSize="10" Foreground="#78909C"
                                   Margin="0,-1,0,0"/>
                    </StackPanel>
                </StackPanel>

                <!-- Right: version -->
                <TextBlock Grid.Column="2" Text="v0.2" FontSize="10" Foreground="#616161"
                           VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- ═══ Configuration Card ═══ -->
        <md:Card Grid.Row="1" Margin="16,12,16,4" Padding="0" md:ElevationAssist.Elevation="Dp2">
            <Expander IsExpanded="True" md:ExpanderAssist.HorizontalHeaderPadding="16"
                      Background="Transparent">
                <Expander.Header>
                    <StackPanel Orientation="Horizontal">
                        <md:PackIcon Kind="Cog" Width="18" Height="18" VerticalAlignment="Center"
                                     Foreground="{StaticResource IdeaOrangeBrush}" Margin="0,0,8,0"/>
                        <TextBlock Text="API Configuration" FontWeight="Medium"/>
                    </StackPanel>
                </Expander.Header>
                <Grid Margin="16,4,16,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Grid.ColumnSpan="3" Orientation="Horizontal" Margin="0,0,0,8">
                        <RadioButton x:Name="RbSpawn" Content="Spawn local API" IsChecked="True"
                                     Margin="0,0,24,0" Style="{StaticResource MaterialDesignRadioButton}"/>
                        <RadioButton x:Name="RbAttach" Content="Attach to running service"
                                     Style="{StaticResource MaterialDesignRadioButton}"/>
                    </StackPanel>

                    <TextBlock Grid.Row="1" Grid.Column="0" Text="IDEA StatiCa folder:"
                               VerticalAlignment="Center" Margin="0,0,12,0"/>
                    <TextBox Grid.Row="1" Grid.Column="1" x:Name="TxtApiPath"
                             Text="C:\Program Files\IDEA StatiCa\StatiCa 26.0"
                             md:HintAssist.Hint="Path to installation or service URL"
                             Margin="0,0,8,0"/>
                    <Button Grid.Row="1" Grid.Column="2" Content="Browse..." Click="BrowseApiPath_Click"
                            Style="{StaticResource IdeaOutlineButton}"/>

                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Project file (.ideaCon):"
                               VerticalAlignment="Center" Margin="0,8,12,0"/>
                    <TextBox Grid.Row="2" Grid.Column="1" x:Name="TxtProjectFile"
                             md:HintAssist.Hint="Select an .ideaCon project file"
                             Margin="0,8,8,0"/>
                    <Button Grid.Row="2" Grid.Column="2" Content="Browse..." Click="BrowseProject_Click"
                            Style="{StaticResource IdeaOutlineButton}" Margin="0,8,0,0"/>
                </Grid>
            </Expander>
        </md:Card>

        <!-- ═══ Main workspace ═══ -->
        <TabControl Grid.Row="2" Margin="16,8,16,8"
                    Style="{StaticResource MaterialDesignNavigationRailTabControl}">

            <!-- Tab 1: Check -->
            <TabItem>
                <TabItem.Header>
                    <StackPanel>
                        <md:PackIcon Kind="ShieldCheck" Width="24" Height="24" HorizontalAlignment="Center"/>
                        <TextBlock Text="Check" HorizontalAlignment="Center" FontSize="11"/>
                    </StackPanel>
                </TabItem.Header>
                <Grid Margin="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Tubular geometry input -->
                    <Expander Grid.Row="0" IsExpanded="False" Margin="0,0,0,8" Background="Transparent">
                        <Expander.Header>
                            <StackPanel Orientation="Horizontal">
                                <md:PackIcon Kind="PipeDisconnected" Width="18" Height="18" VerticalAlignment="Center"
                                             Foreground="{StaticResource NorsokTealBrush}" Margin="0,0,8,0"/>
                                <TextBlock Text="Tubular Member Geometry (optional — for §6.3 member formulas)"
                                           FontWeight="Medium"/>
                            </StackPanel>
                        </Expander.Header>
                        <Grid Margin="8,4,8,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="20"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="20"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="20"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="80"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="D (mm):" VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <TextBox Grid.Column="1" x:Name="TxtDiameter" Text="500"
                                     md:HintAssist.Hint="Outside dia" />
                            <TextBlock Grid.Column="3" Text="t (mm):" VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <TextBox Grid.Column="4" x:Name="TxtThickness" Text="20"
                                     md:HintAssist.Hint="Wall thickness" />
                            <TextBlock Grid.Column="6" Text="L (mm):" VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <TextBox Grid.Column="7" x:Name="TxtLength" Text="5000"
                                     md:HintAssist.Hint="Unbraced length" />
                            <TextBlock Grid.Column="9" Text="k:" VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <TextBox Grid.Column="10" x:Name="TxtKFactor" Text="0.7"
                                     md:HintAssist.Hint="Eff. length" />
                        </Grid>
                    </Expander>

                    <!-- Connections grid -->
                    <DataGrid Grid.Row="1" x:Name="ConnectionsGrid" AutoGenerateColumns="False"
                              IsReadOnly="True" CanUserAddRows="False"
                              md:DataGridAssist.CellPadding="10 6"
                              VerticalScrollBarVisibility="Auto"
                              GridLinesVisibility="Horizontal"
                              BorderThickness="0">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Connection" Binding="{Binding Name}" Width="*"/>
                            <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="130"/>
                            <DataGridTextColumn Header="Max Utilization" Binding="{Binding MaxUtilization, StringFormat=F3}" Width="130"/>
                            <DataGridTextColumn Header="Norsok" Binding="{Binding NorsokPass}" Width="90"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <!-- Action buttons -->
                    <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
                        <Button x:Name="BtnLoadProject" Click="LoadProject_Click"
                                Style="{StaticResource IdeaOutlineButton}" Margin="0,0,8,0">
                            <StackPanel Orientation="Horizontal">
                                <md:PackIcon Kind="FolderOpen" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <TextBlock Text="Load Project" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <Button x:Name="BtnRunCheck" IsEnabled="False" Click="RunCheck_Click"
                                Style="{StaticResource IdeaPrimaryButton}">
                            <StackPanel Orientation="Horizontal">
                                <md:PackIcon Kind="PlayCircleOutline" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <TextBlock Text="Run Norsok Check" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Grid>
            </TabItem>

            <!-- Tab 2: Results -->
            <TabItem x:Name="TabResults" IsEnabled="False">
                <TabItem.Header>
                    <StackPanel>
                        <md:PackIcon Kind="TableLarge" Width="24" Height="24" HorizontalAlignment="Center"/>
                        <TextBlock Text="Results" HorizontalAlignment="Center" FontSize="11"/>
                    </StackPanel>
                </TabItem.Header>
                <Grid Margin="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="NORSOK N-004 §6.3 formula results — per connection, per equation."
                               Style="{StaticResource MaterialDesignBody1TextBlock}" Margin="0,0,0,12"
                               Foreground="#546E7A"/>

                    <DataGrid Grid.Row="1" x:Name="ResultsGrid" AutoGenerateColumns="True"
                              IsReadOnly="True" CanUserAddRows="False"
                              md:DataGridAssist.CellPadding="10 6"
                              VerticalScrollBarVisibility="Auto"
                              GridLinesVisibility="Horizontal"
                              BorderThickness="0"/>
                </Grid>
            </TabItem>

            <!-- Tab 3: Report -->
            <TabItem x:Name="TabReport" IsEnabled="False">
                <TabItem.Header>
                    <StackPanel>
                        <md:PackIcon Kind="FileDocumentOutline" Width="24" Height="24" HorizontalAlignment="Center"/>
                        <TextBlock Text="Report" HorizontalAlignment="Center" FontSize="11"/>
                    </StackPanel>
                </TabItem.Header>
                <Grid Margin="4">
                    <wv2:WebView2 x:Name="ReportWebView" />
                </Grid>
            </TabItem>
        </TabControl>

        <!-- ═══ Log panel ═══ -->
        <md:Card Grid.Row="3" Margin="16,0,16,12" Padding="0" md:ElevationAssist.Elevation="Dp1">
            <Expander IsExpanded="True" md:ExpanderAssist.HorizontalHeaderPadding="16"
                      Background="Transparent">
                <Expander.Header>
                    <StackPanel Orientation="Horizontal">
                        <md:PackIcon Kind="Console" Width="16" Height="16" VerticalAlignment="Center"
                                     Foreground="#78909C" Margin="0,0,8,0"/>
                        <TextBlock Text="Log" Foreground="#78909C"/>
                    </StackPanel>
                </Expander.Header>
                <TextBox x:Name="LogBox" Height="110" IsReadOnly="True"
                         VerticalScrollBarVisibility="Auto"
                         TextWrapping="Wrap" FontFamily="Consolas" FontSize="11.5"
                         Margin="12,0,12,8" Background="#FAFBFC"
                         BorderThickness="0" Foreground="#455A64"/>
            </Expander>
        </md:Card>
    </Grid>
</Window>
